# LLM Provider Configuration
LLM_PROVIDER=anthropic          # anthropic, openai, ollama, custom
LLM_MODEL=claude-sonnet-4-20250514  # Model name/ID
LLM_API_KEY=                    # API key for your provider
LLM_BASE_URL=                   # Optional: custom endpoint (required for ollama/custom)

# Telegram Bot
TELEGRAM_BOT_TOKEN=             # From @BotFather
TELEGRAM_CHAT_ID=               # Your chat ID (get from @userinfobot)

# Web Search (optional but recommended)
TAVILY_API_KEY=                 # From tavily.com (free tier available)

# GitHub (optional, increases rate limits)
GITHUB_TOKEN=                   # Personal access token (public repos scope)

# Schedule (24h format, timezone)
TIMEZONE=UTC
MORNING_DIGEST_HOUR=8
MORNING_DIGEST_MINUTE=0
EVENING_DIGEST_HOUR=18
EVENING_DIGEST_MINUTE=0
SOURCE_SCAN_INTERVAL_HOURS=2
DISCOVERY_INTERVAL_HOURS=6

# Logging
LOG_LEVEL=INFO
